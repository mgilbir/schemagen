{{define "not_schema"}}
{{- $recv := receiverName .Name -}}
{{- if .Description}}
// {{.Name}} - {{.Description}}
{{- end}}
// {{.Name}} accepts any JSON value and validates a root-level "not" constraint.
type {{.Name}} struct {
	_raw json.RawMessage
}

func ({{$recv}} *{{.Name}}) UnmarshalJSON(data []byte) error {
	{{$recv}}._raw = append({{$recv}}._raw[:0], data...)
	return nil
}

func ({{$recv}} {{.Name}}) MarshalJSON() ([]byte, error) {
	if len({{$recv}}._raw) == 0 {
		return []byte("null"), nil
	}
	return {{$recv}}._raw, nil
}

func ({{$recv}} {{.Name}}) Raw() json.RawMessage { return {{$recv}}._raw }

func ({{$recv}} {{.Name}}) String() string { return string({{$recv}}._raw) }

// Validate checks {{.Name}} against its JSON Schema "not" constraint.
func ({{$recv}} {{.Name}}) Validate() error {
	{{- if .IsForbidden}}
	return fmt.Errorf("not: value is forbidden (not schema matches all values)")
	{{- else if or .NotTypes .NotBranches}}
	// Decode raw JSON to determine the value's type.
	var _v any
	if _err := json.Unmarshal({{$recv}}._raw, &_v); _err != nil {
		return fmt.Errorf("not: cannot decode value: %w", _err)
	}
	{{- range .NotTypes}}
	{{- if eq . "integer"}}
	if _f, _fOk := _v.(float64); _fOk && _f == math.Trunc(_f) && !math.IsInf(_f, 0) {
		return fmt.Errorf("not: value must not be integer")
	}
	{{- else if eq . "number"}}
	if _, _fOk := _v.(float64); _fOk {
		return fmt.Errorf("not: value must not be number")
	}
	{{- else if eq . "string"}}
	if _, _sOk := _v.(string); _sOk {
		return fmt.Errorf("not: value must not be string")
	}
	{{- else if eq . "boolean"}}
	if _, _bOk := _v.(bool); _bOk {
		return fmt.Errorf("not: value must not be boolean")
	}
	{{- else if eq . "null"}}
	if _v == nil {
		return fmt.Errorf("not: value must not be null")
	}
	{{- else if eq . "array"}}
	if _, _aOk := _v.([]any); _aOk {
		return fmt.Errorf("not: value must not be array")
	}
	{{- else if eq . "object"}}
	if _, _oOk := _v.(map[string]any); _oOk {
		return fmt.Errorf("not: value must not be object")
	}
	{{- end}}
	{{- end}}
	{{- range $bi, $branch := .NotBranches}}
	{
		_branchMatches := true
		{{- range $branch.Types}}
		{{- if eq . "integer"}}
		if _f, _fOk := _v.(float64); !_fOk || _f != math.Trunc(_f) || math.IsInf(_f, 0) {
			_branchMatches = false
		}
		{{- else if eq . "number"}}
		if _, _fOk := _v.(float64); !_fOk {
			_branchMatches = false
		}
		{{- else if eq . "string"}}
		if _, _sOk := _v.(string); !_sOk {
			_branchMatches = false
		}
		{{- else if eq . "boolean"}}
		if _, _bOk := _v.(bool); !_bOk {
			_branchMatches = false
		}
		{{- else if eq . "null"}}
		if _v != nil {
			_branchMatches = false
		}
		{{- else if eq . "array"}}
		if _, _aOk := _v.([]any); !_aOk {
			_branchMatches = false
		}
		{{- else if eq . "object"}}
		if _, _oOk := _v.(map[string]any); !_oOk {
			_branchMatches = false
		}
		{{- end}}
		{{- end}}
		{{- if $branch.Properties}}
		_obj, _objOk := _v.(map[string]any)
		if !_objOk {
			_branchMatches = false
		}
		{{- range $branch.Properties}}
		if _branchMatches {
			_propVal, _propOk := _obj[{{printf "%q" .Name}}]
			if !_propOk {
				_branchMatches = false
			} else {
				{{- if eq .JSONType "integer"}}
				_f, _fOk := _propVal.(float64)
				if !_fOk || _f != math.Trunc(_f) || math.IsInf(_f, 0) { _branchMatches = false }
				{{- else if eq .JSONType "number"}}
				if _, _fOk := _propVal.(float64); !_fOk { _branchMatches = false }
				{{- else if eq .JSONType "string"}}
				if _, _sOk := _propVal.(string); !_sOk { _branchMatches = false }
				{{- else if eq .JSONType "boolean"}}
				if _, _bOk := _propVal.(bool); !_bOk { _branchMatches = false }
				{{- else if eq .JSONType "null"}}
				if _propVal != nil { _branchMatches = false }
				{{- else if eq .JSONType "array"}}
				if _, _aOk := _propVal.([]any); !_aOk { _branchMatches = false }
				{{- else if eq .JSONType "object"}}
				if _, _oOk := _propVal.(map[string]any); !_oOk { _branchMatches = false }
				{{- end}}
			}
		}
		{{- end}}
		{{- end}}
		{{- range $branch.Validations}}
		if _branchMatches {
			{{- if or (eq .RuleType "minimum") (eq .RuleType "maximum") (eq .RuleType "exclusiveMinimum") (eq .RuleType "exclusiveMaximum") (eq .RuleType "multipleOf")}}
			_num, _numOk := _v.(float64)
			if !_numOk {
				_branchMatches = false
			} else {
				{{- if eq .RuleType "minimum"}}
				if _num < {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "maximum"}}
				if _num > {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "exclusiveMinimum"}}
				if _num <= {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "exclusiveMaximum"}}
				if _num >= {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "multipleOf"}}
				_q := _num / {{.Value}}
				if math.Abs(_q - math.Round(_q)) > 1e-9 { _branchMatches = false }
				{{- end}}
			}
			{{- else if or (eq .RuleType "minLength") (eq .RuleType "maxLength") (eq .RuleType "pattern")}}
			_s, _sOk := _v.(string)
			if !_sOk {
				_branchMatches = false
			} else {
				{{- if eq .RuleType "minLength"}}
				if utf8.RuneCountInString(_s) < {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "maxLength"}}
				if utf8.RuneCountInString(_s) > {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "pattern"}}
				if _matched, _ := ecma262.MatchString({{ecmaPattern .Value}}, ecmaflags.Unicode, _s); !_matched { _branchMatches = false }
				{{- end}}
			}
			{{- else if or (eq .RuleType "minItems") (eq .RuleType "maxItems")}}
			_arr, _arrOk := _v.([]any)
			if !_arrOk {
				_branchMatches = false
			} else {
				{{- if eq .RuleType "minItems"}}
				if len(_arr) < {{.Value}} { _branchMatches = false }
				{{- else if eq .RuleType "maxItems"}}
				if len(_arr) > {{.Value}} { _branchMatches = false }
				{{- end}}
			}
			{{- end}}
		}
		{{- end}}
		if _branchMatches {
			return fmt.Errorf("not: value matches forbidden branch {{$bi}}")
		}
	}
	{{- end}}
	return nil
	{{- end}}
}
{{- end}}
