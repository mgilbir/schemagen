{{define "alias"}}
{{- if .Description}}
// {{.Name}} - {{.Description}}
{{- end}}
type {{.Name}} {{goType .Underlying}}
{{- if and .CanHaveMethods .NeedsNullCheck}}
{{template "alias_unmarshal" .}}
{{- end}}
{{- if .CanHaveMethods}}
{{template "alias_validate" .}}
{{- end}}
{{- end}}

{{define "alias_unmarshal"}}
{{- $recv := receiverName .Name -}}

func ({{$recv}} *{{.Name}}) UnmarshalJSON(data []byte) error {
	if string(data) == "null" {
		return fmt.Errorf("null is not allowed for type {{.Name}}")
	}
	type Alias {{.Name}}
	return json.Unmarshal(data, (*Alias)({{$recv}}))
}
{{- end}}

{{define "alias_validate"}}
{{- $recv := receiverName .Name -}}

// Validate checks {{.Name}} against its JSON Schema constraints.
func ({{$recv}} {{.Name}}) Validate() error {
	{{- range .Validations}}
	{{- if eq .RuleType "minLength"}}
	if utf8.RuneCountInString(string({{$recv}})) < {{.Value}} {
		return fmt.Errorf("value: length %d is less than minimum {{.Value}}", utf8.RuneCountInString(string({{$recv}})))
	}
	{{- end}}
	{{- if eq .RuleType "maxLength"}}
	if utf8.RuneCountInString(string({{$recv}})) > {{.Value}} {
		return fmt.Errorf("value: length %d exceeds maximum {{.Value}}", utf8.RuneCountInString(string({{$recv}})))
	}
	{{- end}}
	{{- if eq .RuleType "minimum"}}
	if float64({{$recv}}) < {{.Value}} {
		return fmt.Errorf("value: %v is less than minimum {{.Value}}", {{$recv}})
	}
	{{- end}}
	{{- if eq .RuleType "maximum"}}
	if float64({{$recv}}) > {{.Value}} {
		return fmt.Errorf("value: %v exceeds maximum {{.Value}}", {{$recv}})
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMinimum"}}
	if float64({{$recv}}) <= {{.Value}} {
		return fmt.Errorf("value: %v must be greater than {{.Value}}", {{$recv}})
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMaximum"}}
	if float64({{$recv}}) >= {{.Value}} {
		return fmt.Errorf("value: %v must be less than {{.Value}}", {{$recv}})
	}
	{{- end}}
	{{- if eq .RuleType "multipleOf"}}
	{
		q := float64({{$recv}}) / {{.Value}}
		if math.Abs(q - math.Round(q)) > 1e-9 {
			return fmt.Errorf("value: %v is not a multiple of {{.Value}}", {{$recv}})
		}
	}
	{{- end}}
	{{- if eq .RuleType "pattern"}}
	if matched, _ := ecma262.MatchString({{printf "%q" .Value}}, ecmaflags.Unicode, string({{$recv}})); !matched {
		return fmt.Errorf("value: %q does not match pattern %s", {{$recv}}, {{printf "%q" .Value}})
	}
	{{- end}}
	{{- if eq .RuleType "minItems"}}
	if len({{$recv}}) < {{.Value}} {
		return fmt.Errorf("value: has %d items, minimum is {{.Value}}", len({{$recv}}))
	}
	{{- end}}
	{{- if eq .RuleType "maxItems"}}
	if len({{$recv}}) > {{.Value}} {
		return fmt.Errorf("value: has %d items, maximum is {{.Value}}", len({{$recv}}))
	}
	{{- end}}
	{{- if eq .RuleType "uniqueItems"}}
	{
		seen := make(map[string]bool, len({{$recv}}))
		for i, item := range {{$recv}} {
			b, err := json.Marshal(item)
			if err != nil {
				return fmt.Errorf("value: uniqueItems check: marshal error at index %d: %w", i, err)
			}
			key := string(b)
			if seen[key] {
				return fmt.Errorf("value: items are not unique (duplicate at index %d)", i)
			}
			seen[key] = true
		}
	}
	{{- end}}
	{{- end}}
	return nil
}
{{- end}}
