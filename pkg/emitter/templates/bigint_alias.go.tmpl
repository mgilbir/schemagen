func ({{$recv}} {{.Name}}) MarshalJSON() ([]byte, error) {
	if {{$recv}}._isBigInt && {{$recv}}._bigInt != nil {
		return []byte({{$recv}}._bigInt.String()), nil
	}
	return json.Marshal({{$recv}}._int64)
}
