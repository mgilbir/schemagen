	{{- if eq .RuleType "maximum"}}
	{
		_val := new(big.Float).SetPrec(256).SetInt({{$recv}}.BigInt())
		_limit := new(big.Float).SetPrec(256)
		_limit.SetString("{{.Value}}")
		if _val.Cmp(_limit) > 0 {
			return fmt.Errorf("value: %s exceeds maximum {{.Value}}", {{$recv}}.BigInt().String())
		}
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMinimum"}}
	{
		_val := new(big.Float).SetPrec(256).SetInt({{$recv}}.BigInt())
		_limit := new(big.Float).SetPrec(256)
		_limit.SetString("{{.Value}}")
		if _val.Cmp(_limit) <= 0 {
			return fmt.Errorf("value: %s must be greater than {{.Value}}", {{$recv}}.BigInt().String())
		}
