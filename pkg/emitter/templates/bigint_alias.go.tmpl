		return {{$recv}}._bigInt
	}
	return big.NewInt({{$recv}}._int64)
}
func ({{$recv}} {{.Name}}) IsBigInt() bool { return {{$recv}}._isBigInt }
func ({{$recv}} {{.Name}}) String() string { return {{$recv}}.BigInt().String() }
