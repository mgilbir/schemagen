func ({{$recv}} *{{.Name}}) UnmarshalJSON(data []byte) error {
	{{- if .NeedsNullCheck}}
	if string(data) == "null" {
		return fmt.Errorf("null is not allowed for type {{.Name}}")
	}
	{{- end}}
	// Reject JSON strings (e.g., "1").
	if len(data) > 0 && data[0] == '"' {
		return fmt.Errorf("cannot unmarshal string into Go value of type {{.Name}}")
	}
	var _n json.Number
	if _err := json.Unmarshal(data, &_n); _err != nil {
		return _err
	}
	// Try int64 first.
	if _i, _iErr := _n.Int64(); _iErr == nil {
		{{$recv}}._int64 = _i
		{{$recv}}._isBigInt = false
		{{$recv}}._bigInt = nil
		return nil
	}
	// Try float with zero fractional part only for float-notation numbers (e.g., 1.0, 1e2).
	_s := _n.String()
	if strings.ContainsAny(_s, ".eE") {
		if _f, _fErr := _n.Float64(); _fErr == nil {
			if _f == math.Trunc(_f) && !math.IsInf(_f, 0) && _f >= -9.223372036854776e+18 && _f <= 9.223372036854776e+18 {
				_i64 := int64(_f)
				// Verify no precision loss: int64 → float64 must round-trip.
				if float64(_i64) == _f {
					{{$recv}}._int64 = _i64
					{{$recv}}._isBigInt = false
					{{$recv}}._bigInt = nil
					return nil
				}
			}
		}
	}
	// Try big.Int for values that overflow int64.
	_bi := new(big.Int)
	// Handle float-format bignums (e.g., 1e100).
	if strings.ContainsAny(_s, ".eE") {
		_bf := new(big.Float)
		if _, _ok := _bf.SetString(_s); _ok {
			if _bf.IsInt() {
				_bf.Int(_bi)
				{{$recv}}._bigInt = _bi
				{{$recv}}._isBigInt = true
				{{$recv}}._int64 = 0
				return nil
			}
		}
		return fmt.Errorf("value %s is not an integer", _s)
	}
	if _, _ok := _bi.SetString(_s, 10); _ok {
		{{$recv}}._bigInt = _bi
		{{$recv}}._isBigInt = true
		{{$recv}}._int64 = 0
		return nil
	}
	return fmt.Errorf("value %s is not a valid integer", _s)
}
