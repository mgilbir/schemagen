{{define "unmarshal"}}
{{- $struct := . -}}
{{- $recv := receiverName .Name -}}

func ({{$recv}} *{{$struct.Name}}) UnmarshalJSON(data []byte) error {
	{{- if $struct.NeedsNullCheck}}
	if string(data) == "null" {
		return fmt.Errorf("null is not allowed for type {{$struct.Name}}")
	}
	{{- end}}
	{{- if $struct.AcceptNonObject}}
	// Schema has no explicit "type":"object" — object constraints are type-conditional.
	// Non-object JSON data is silently accepted; raw bytes are preserved for roundtrip.
	{{- if $struct.NeedsNullCheck}}
	if len(data) == 0 || (data[0] != '{' && string(data) != "null") {
	{{- else}}
	if len(data) == 0 || data[0] != '{' {
	{{- end}}
		{{$recv}}._nonObject = true
		{{$recv}}._rawNonObject = append({{$recv}}._rawNonObject[:0], data...)
		return nil
	}
	{{- end}}
	type Alias {{$struct.Name}}
	aux := &struct {
		*Alias
		{{- range $struct.OneOfs}}
		{{- if .JSONName}}
		{{.FieldName}} json.RawMessage `json:"{{.JSONName}}"`
		{{- end}}
		{{- end}}
	}{
		Alias: (*Alias)({{$recv}}),
	}

	if err := json.Unmarshal(data, aux); err != nil {
		return err
	}
	{{- if hasManualFields $struct.Fields}}

	// Extract fields with JSON names that cannot be represented in struct tags.
	{
		var raw map[string]json.RawMessage
		if err := json.Unmarshal(data, &raw); err != nil {
			return err
		}
		{{- range $struct.Fields}}
		{{- if .ManualJSON}}
		if v, ok := raw[{{printf "%q" .JSONName}}]; ok {
			if err := json.Unmarshal(v, &{{$recv}}.{{.Name}}); err != nil {
				return fmt.Errorf("unmarshaling {{$struct.Name}}.{{.Name}}: %w", err)
			}
		}
		{{- end}}
		{{- end}}
	}
	{{- end}}
	{{- range $oof := $struct.OneOfs}}

	{
		{{- if $oof.JSONName}}
		oneofData := aux.{{$oof.FieldName}}
		{{- else}}
		// Top-level oneOf: the entire JSON object is the variant data.
		oneofData := json.RawMessage(data)
		{{- end}}
		if len(oneofData) > 0 && string(oneofData) != "null" {
			{{- if $oof.HasDiscriminator}}
			// Discriminator-based dispatch on "{{$oof.DiscriminatorField}}"
			discVal, discErr := oneofDiscriminatorValue(oneofData, "{{$oof.DiscriminatorField}}")
			if discErr != nil {
				return fmt.Errorf("{{$struct.Name}}.{{$oof.FieldName}}: %w", discErr)
			}
			switch discVal {
			{{- range $i, $v := $oof.Variants}}
			{{- if $v.DiscriminatorValue}}
			case "{{$v.DiscriminatorValue}}":
				var candidate {{goType $v.Type}}
				if err := json.Unmarshal(oneofData, &candidate); err != nil {
					return fmt.Errorf("{{$struct.Name}}.{{$oof.FieldName}} (variant {{$v.FieldName}}): %w", err)
				}
				{{$recv}}.{{$oof.FieldName}} = &{{$v.WrapperName}}{{"{"}}{{$v.FieldName}}: candidate}
			{{- end}}
			{{- end}}
			default:
				return fmt.Errorf("{{$struct.Name}}.{{$oof.FieldName}}: unknown discriminator value %q for field \"{{$oof.DiscriminatorField}}\"", discVal)
			}
			{{- else}}
			var oneofMatched int
			var oneofLastErr error
			{{- range $i, $v := $oof.Variants}}

			// Try variant: {{$v.FieldName}}
			{
				{{- if $v.RequiredFields}}
				if oneofHasRequiredFields(oneofData, {{requiredFieldsList $v.RequiredFields}}) {
				{{- end}}
					var candidate {{goType $v.Type}}
					if err := json.Unmarshal(oneofData, &candidate); err == nil {
						{{$recv}}.{{$oof.FieldName}} = &{{$v.WrapperName}}{{"{"}}{{$v.FieldName}}: candidate}
						oneofMatched++
					} else {
						oneofLastErr = err
					}
				{{- if $v.RequiredFields}}
				}
				{{- end}}
			}
			{{- end}}

			if oneofMatched == 0 {
				return fmt.Errorf("{{$struct.Name}}.{{$oof.FieldName}}: no matching oneOf variant: %w", oneofLastErr)
			}
			if oneofMatched > 1 {
				return fmt.Errorf("{{$struct.Name}}.{{$oof.FieldName}}: multiple oneOf variants matched (%d), expected exactly 1", oneofMatched)
			}
			{{- end}}
		}
	}
	{{- end}}

	{{- if or $struct.AdditionalProperties $struct.HasPatternProperties $struct.HasRequiredFields $struct.NeedsJSONKeys $struct.NeedsRawProps}}
	{
		var raw map[string]json.RawMessage
		if err := json.Unmarshal(data, &raw); err != nil {
			return err
		}
		{{- if $struct.NeedsJSONKeys}}
		{{$recv}}._jsonKeys = make(map[string]bool, len(raw))
		for _k := range raw {
			{{$recv}}._jsonKeys[_k] = true
		}
		{{- end}}
		{{- if $struct.NeedsRawProps}}
		{{$recv}}._jsonRawProps = raw
		{{- end}}
		{{- if or $struct.AdditionalProperties $struct.HasPatternProperties}}
		knownFields := map[string]bool{
			{{- if $struct.HasOwnPropertyNames}}
			{{- /* Only parent-level properties are "known" for additionalProperties routing.
			       Properties merged from allOf sub-schemas are NOT known — they must be
			       routed to additionalProperties per the JSON Schema spec (section 10.2). */}}
			{{- range $struct.OwnPropertyNames}}
			{{printf "%q" .}}: true,
			{{- end}}
			{{- else}}
			{{- range $struct.Fields}}
			{{printf "%q" .JSONName}}: true,
			{{- end}}
			{{- end}}
			{{- range $struct.OneOfs}}
			{{- if .JSONName}}
			{{printf "%q" .JSONName}}: true,
			{{- end}}
			{{- end}}
		}
		{{- if $struct.HasPatternProperties}}
		patternRegexps := []*ecma262.Regexp{
			{{- range $struct.PatternProperties}}
			ecma262.MustCompile({{ecmaPattern .Pattern}}, ecmaflags.Unicode),
			{{- end}}
		}
		{{- end}}
		for rawKey, rawVal := range raw {
			if knownFields[rawKey] {
				continue
			}
			{{- if $struct.HasPatternProperties}}
			matchesPattern := false
			for _, re := range patternRegexps {
				if re.MatchString(rawKey) {
					matchesPattern = true
					break
				}
			}
			if matchesPattern {
				if {{$recv}}.PatternProperties == nil {
					{{$recv}}.PatternProperties = make(map[string]json.RawMessage)
				}
				{{$recv}}.PatternProperties[rawKey] = rawVal
				continue
			}
			{{- end}}
			{{- if $struct.AdditionalProperties}}
			if {{$recv}}.AdditionalProperties == nil {
				{{$recv}}.AdditionalProperties = make(map[string]{{goType $struct.AdditionalProperties.ValueType}})
			}
			{{- if isRawMessage $struct.AdditionalProperties.ValueType}}
			{{$recv}}.AdditionalProperties[rawKey] = rawVal
			{{- else}}
			var val {{goType $struct.AdditionalProperties.ValueType}}
			if err := json.Unmarshal(rawVal, &val); err != nil {
				return fmt.Errorf("additionalProperties[%s]: %w", rawKey, err)
			}
			{{$recv}}.AdditionalProperties[rawKey] = val
			{{- end}}
			{{- end}}
		}
		{{- end}}
	}
	{{- end}}
	{{- /* _jsonKeys for dependentSchemas and optional validation is populated in the raw block above */}}

	return nil
}
{{- end}}
