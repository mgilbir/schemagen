{{define "type_only_schema"}}
{{- $recv := receiverName .Name -}}
{{- if .Description}}
// {{.Name}} - {{.Description}}
{{- end}}
// {{.Name}} accepts any JSON value and validates that it is one of the allowed types.
type {{.Name}} struct {
	_raw json.RawMessage
}

func ({{$recv}} *{{.Name}}) UnmarshalJSON(data []byte) error {
	{{$recv}}._raw = append({{$recv}}._raw[:0], data...)
	return nil
}

func ({{$recv}} {{.Name}}) MarshalJSON() ([]byte, error) {
	if len({{$recv}}._raw) == 0 {
		return []byte("null"), nil
	}
	return {{$recv}}._raw, nil
}

func ({{$recv}} {{.Name}}) Raw() json.RawMessage { return {{$recv}}._raw }

func ({{$recv}} {{.Name}}) String() string { return string({{$recv}}._raw) }

// Validate checks {{.Name}} against its JSON Schema type constraint.
func ({{$recv}} {{.Name}}) Validate() error {
	var _v any
	if _err := json.Unmarshal({{$recv}}._raw, &_v); _err != nil {
		return fmt.Errorf("type: cannot decode value: %w", _err)
	}
	{{- $nullOk := false}}{{$numOk := false}}{{$intOk := false}}{{$strOk := false}}{{$boolOk := false}}{{$arrOk := false}}{{$objOk := false}}
	{{- range .AllowedTypes -}}
		{{- if eq . "null"}}{{$nullOk = true}}
		{{- else if eq . "number"}}{{$numOk = true}}
		{{- else if eq . "integer"}}{{$intOk = true}}
		{{- else if eq . "string"}}{{$strOk = true}}
		{{- else if eq . "boolean"}}{{$boolOk = true}}
		{{- else if eq . "array"}}{{$arrOk = true}}
		{{- else if eq . "object"}}{{$objOk = true}}
		{{- end}}
	{{- end}}
	if _v == nil {
		{{- if $nullOk}}
		return nil
		{{- else}}
		return fmt.Errorf("type: null is not allowed")
		{{- end}}
	}
	switch _tv := _v.(type) {
	case float64:
		{{- if $numOk}}
		_ = _tv
		return nil
		{{- else if $intOk}}
		if _tv != math.Trunc(_tv) || math.IsInf(_tv, 0) {
			return fmt.Errorf("type: expected integer, got number")
		}
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: number is not allowed")
		{{- end}}
	case string:
		{{- if $strOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: string is not allowed")
		{{- end}}
	case bool:
		{{- if $boolOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: boolean is not allowed")
		{{- end}}
	case []any:
		{{- if $arrOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: array is not allowed")
		{{- end}}
	case map[string]any:
		{{- if $objOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: object is not allowed")
		{{- end}}
	default:
		return fmt.Errorf("type: unexpected value type %T", _v)
	}
}
{{- end}}
