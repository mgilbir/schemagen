{{define "type_only_schema"}}
{{- $recv := receiverName .Name -}}
{{- if .Description}}
// {{.Name}} - {{.Description}}
{{- end}}
// {{.Name}} accepts any JSON value and validates that it is one of the allowed types.
type {{.Name}} struct {
	_raw json.RawMessage
}

func ({{$recv}} *{{.Name}}) UnmarshalJSON(data []byte) error {
	{{$recv}}._raw = append({{$recv}}._raw[:0], data...)
	return nil
}

func ({{$recv}} {{.Name}}) MarshalJSON() ([]byte, error) {
	if len({{$recv}}._raw) == 0 {
		return []byte("null"), nil
	}
	return {{$recv}}._raw, nil
}

func ({{$recv}} {{.Name}}) Raw() json.RawMessage { return {{$recv}}._raw }

func ({{$recv}} {{.Name}}) String() string { return string({{$recv}}._raw) }

// Validate checks {{.Name}} against its JSON Schema type constraint.
func ({{$recv}} {{.Name}}) Validate() error {
	var _v any
	if _err := json.Unmarshal({{$recv}}._raw, &_v); _err != nil {
		return fmt.Errorf("type: cannot decode value: %w", _err)
	}
	_typeBranchValid := false
	{{- range $bi, $branch := .TypeBranches}}
	{
		_branchMatches := true
		{{- range $branch.AllowedTypes}}
		{{- if eq . "object"}}
		if _, _ok := _v.(map[string]any); !_ok { _branchMatches = false }
		{{- else if eq . "integer"}}
		if _f, _ok := _v.(float64); !_ok || _f != math.Trunc(_f) || math.IsInf(_f, 0) { _branchMatches = false }
		{{- else if eq . "number"}}
		if _, _ok := _v.(float64); !_ok { _branchMatches = false }
		{{- else if eq . "string"}}
		if _, _ok := _v.(string); !_ok { _branchMatches = false }
		{{- else if eq . "boolean"}}
		if _, _ok := _v.(bool); !_ok { _branchMatches = false }
		{{- else if eq . "null"}}
		if _v != nil { _branchMatches = false }
		{{- else if eq . "array"}}
		if _, _ok := _v.([]any); !_ok { _branchMatches = false }
		{{- end}}
		{{- end}}
		_obj, _objOk := _v.(map[string]any)
		if !_objOk {
			_branchMatches = false
		}
		{{- range $branch.Properties}}
		if _branchMatches {
			_propVal, _propOk := _obj[{{printf "%q" .Name}}]
			if !_propOk {
				{{- if .Required}}
				_branchMatches = false
				{{- end}}
			} else {
				{{- if eq .JSONType "integer"}}
				_f, _fOk := _propVal.(float64)
				if !_fOk || _f != math.Trunc(_f) || math.IsInf(_f, 0) { _branchMatches = false }
				{{- else if eq .JSONType "number"}}
				if _, _fOk := _propVal.(float64); !_fOk { _branchMatches = false }
				{{- else if eq .JSONType "string"}}
				if _, _sOk := _propVal.(string); !_sOk { _branchMatches = false }
				{{- else if eq .JSONType "boolean"}}
				if _, _bOk := _propVal.(bool); !_bOk { _branchMatches = false }
				{{- else if eq .JSONType "null"}}
				if _propVal != nil { _branchMatches = false }
				{{- else if eq .JSONType "array"}}
				if _, _aOk := _propVal.([]any); !_aOk { _branchMatches = false }
				{{- else if eq .JSONType "object"}}
				if _, _oOk := _propVal.(map[string]any); !_oOk { _branchMatches = false }
				{{- end}}
			}
		}
		{{- end}}
		if _branchMatches {
			_typeBranchValid = true
		}
	}
	{{- end}}
	if _typeBranchValid {
		return nil
	}
	{{- $nullOk := false}}{{$numOk := false}}{{$intOk := false}}{{$strOk := false}}{{$boolOk := false}}{{$arrOk := false}}{{$objOk := false}}
	{{- range .AllowedTypes -}}
		{{- if eq . "null"}}{{$nullOk = true}}
		{{- else if eq . "number"}}{{$numOk = true}}
		{{- else if eq . "integer"}}{{$intOk = true}}
		{{- else if eq . "string"}}{{$strOk = true}}
		{{- else if eq . "boolean"}}{{$boolOk = true}}
		{{- else if eq . "array"}}{{$arrOk = true}}
		{{- else if eq . "object"}}{{$objOk = true}}
		{{- end}}
	{{- end}}
	if _v == nil {
		{{- if $nullOk}}
		return nil
		{{- else}}
		return fmt.Errorf("type: null is not allowed")
		{{- end}}
	}
	switch _tv := _v.(type) {
	case float64:
		{{- if $numOk}}
		_ = _tv
		return nil
		{{- else if $intOk}}
		if _tv != math.Trunc(_tv) || math.IsInf(_tv, 0) {
			return fmt.Errorf("type: expected integer, got number")
		}
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: number is not allowed")
		{{- end}}
	case string:
		{{- if $strOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: string is not allowed")
		{{- end}}
	case bool:
		{{- if $boolOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: boolean is not allowed")
		{{- end}}
	case []any:
		{{- if $arrOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: array is not allowed")
		{{- end}}
	case map[string]any:
		{{- if $objOk}}
		_ = _tv
		return nil
		{{- else}}
		_ = _tv
		return fmt.Errorf("type: object is not allowed")
		{{- end}}
	default:
		return fmt.Errorf("type: unexpected value type %T", _v)
	}
}
{{- end}}
