{{define "validate"}}
{{- $struct := . -}}
{{- $recv := receiverName .Name -}}

// Validate checks {{$struct.Name}} against its JSON Schema constraints.
func ({{$recv}} {{$struct.Name}}) Validate() error {
	{{- if $struct.AcceptNonObject}}
	// Non-object data was silently accepted — validate non-object constraints if any.
	if {{$recv}}._nonObject {
		{{- if gt (len $struct.NonObjectValidations) 0}}
		v := {{$recv}}._rawNonObject
		_ = v
		{{- range $struct.NonObjectValidations}}
		{{- if or (eq .RuleType "ppMinimum") (eq .RuleType "ppMaximum") (eq .RuleType "ppExclusiveMinimum") (eq .RuleType "ppExclusiveMaximum") (eq .RuleType "ppMultipleOf")}}
		{
			var num float64
			if err := json.Unmarshal(v, &num); err == nil {
				{{- if eq .RuleType "ppMinimum"}}
				if num < {{.Value}} {
					return fmt.Errorf("value %v is less than minimum {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppMaximum"}}
				if num > {{.Value}} {
					return fmt.Errorf("value %v exceeds maximum {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppExclusiveMinimum"}}
				if num <= {{.Value}} {
					return fmt.Errorf("value %v must be greater than {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppExclusiveMaximum"}}
				if num >= {{.Value}} {
					return fmt.Errorf("value %v must be less than {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppMultipleOf"}}
				q := num / {{.Value}}
				if math.Abs(q - math.Round(q)) > 1e-9 {
					return fmt.Errorf("value %v is not a multiple of {{.Value}}", num)
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- if or (eq .RuleType "ppMinLength") (eq .RuleType "ppMaxLength")}}
		{
			var s string
			if err := json.Unmarshal(v, &s); err == nil {
				{{- if eq .RuleType "ppMinLength"}}
				if utf8.RuneCountInString(s) < {{.Value}} {
					return fmt.Errorf("string length is less than minLength {{.Value}}")
				}
				{{- end}}
				{{- if eq .RuleType "ppMaxLength"}}
				if utf8.RuneCountInString(s) > {{.Value}} {
					return fmt.Errorf("string length exceeds maxLength {{.Value}}")
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- if eq .RuleType "ppPattern"}}
		{
			var s string
			if err := json.Unmarshal(v, &s); err == nil {
				re := regexp.MustCompile({{printf "%q" .Value}})
				if !re.MatchString(s) {
					return fmt.Errorf("value does not match pattern {{.Value}}")
				}
			}
		}
		{{- end}}
		{{- if or (eq .RuleType "ppMinItems") (eq .RuleType "ppMaxItems")}}
		{
			var arr []json.RawMessage
			if err := json.Unmarshal(v, &arr); err == nil {
				{{- if eq .RuleType "ppMinItems"}}
				if len(arr) < {{.Value}} {
					return fmt.Errorf("array length %d is less than minItems {{.Value}}", len(arr))
				}
				{{- end}}
				{{- if eq .RuleType "ppMaxItems"}}
				if len(arr) > {{.Value}} {
					return fmt.Errorf("array length %d exceeds maxItems {{.Value}}", len(arr))
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- if eq .RuleType "ppType"}}
		{
			b := bytes.TrimSpace(v)
			var jt string
			if len(b) == 0 {
				jt = "unknown"
			} else {
				switch b[0] {
				case '"': jt = "string"
				case '{': jt = "object"
				case '[': jt = "array"
				case 't', 'f': jt = "boolean"
				case 'n': jt = "null"
				default:
					jt = "number"
					isInt := true
					for _, c := range b {
						if c == '.' || c == 'e' || c == 'E' {
							isInt = false
							break
						}
					}
					if isInt {
						jt = "integer"
					}
				}
			}
			{{- $want := ppTypeValue .Value}}
			{{- if eq $want "integer"}}
			if jt != "integer" {
				return fmt.Errorf("value must be integer")
			}
			{{- else if eq $want "number"}}
			if jt != "integer" && jt != "number" {
				return fmt.Errorf("value must be number")
			}
			{{- else}}
			if jt != {{printf "%q" $want}} {
				return fmt.Errorf("value must be {{$want}}")
			}
			{{- end}}
		}
		{{- end}}
		{{- end}}
		{{- end}}
		return nil
	}
	{{- end}}
	{{- range $struct.Validations}}
	{{- if .Optional}}
	if {{$recv}}._jsonKeys[{{printf "%q" .JSONName}}] {
	{{- end}}
	{{- if eq .RuleType "minLength"}}
	if utf8.RuneCountInString({{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: length %d is less than minimum {{.Value}}", utf8.RuneCountInString({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- if eq .RuleType "maxLength"}}
	if utf8.RuneCountInString({{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: length %d exceeds maximum {{.Value}}", utf8.RuneCountInString({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- if eq .RuleType "minimum"}}
	if float64({{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v is less than minimum {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "maximum"}}
	if float64({{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v exceeds maximum {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMinimum"}}
	if float64({{$recv}}.{{.FieldName}}) <= {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v must be greater than {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMaximum"}}
	if float64({{$recv}}.{{.FieldName}}) >= {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v must be less than {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "multipleOf"}}
	{
		q := float64({{$recv}}.{{.FieldName}}) / {{.Value}}
		if math.Abs(q - math.Round(q)) > 1e-9 {
			return fmt.Errorf("{{.JSONName}}: value %v is not a multiple of {{.Value}}", {{$recv}}.{{.FieldName}})
		}
	}
	{{- end}}
	{{- if eq .RuleType "pattern"}}
	if matched, _ := ecma262.MatchString({{printf "%q" .Value}}, ecmaflags.Unicode, {{$recv}}.{{.FieldName}}); !matched {
		return fmt.Errorf("{{.JSONName}}: value %q does not match pattern %s", {{$recv}}.{{.FieldName}}, {{printf "%q" .Value}})
	}
	{{- end}}
	{{- if eq .RuleType "minItems"}}
	{{- if .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil && len(*{{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, minimum is {{.Value}}", len(*{{$recv}}.{{.FieldName}}))
	}
	{{- else}}
	if len({{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, minimum is {{.Value}}", len({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- end}}
	{{- if eq .RuleType "maxItems"}}
	{{- if .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil && len(*{{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, maximum is {{.Value}}", len(*{{$recv}}.{{.FieldName}}))
	}
	{{- else}}
	if len({{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, maximum is {{.Value}}", len({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- end}}
	{{- if eq .RuleType "uniqueItems"}}
	{
		{{- if .IsPointer}}
		arr := *{{$recv}}.{{.FieldName}}
		{{- else}}
		arr := {{$recv}}.{{.FieldName}}
		{{- end}}
		seen := make(map[string]bool, len(arr))
		for i, item := range arr {
			b, err := json.Marshal(item)
			if err != nil {
				return fmt.Errorf("{{.JSONName}}: uniqueItems check: marshal error at index %d: %w", i, err)
			}
			key := string(b)
			if seen[key] {
				return fmt.Errorf("{{.JSONName}}: items are not unique (duplicate at index %d)", i)
			}
			seen[key] = true
		}
	}
	{{- end}}
	{{- if eq .RuleType "forbidden"}}
	if {{$recv}}.{{.FieldName}} != nil {
		return fmt.Errorf("{{.JSONName}}: property is forbidden (not: {})")
	}
	{{- end}}
	{{- if eq .RuleType "maxProperties"}}
	{
		totalProps := {{len $struct.Fields}} + len({{$recv}}.AdditionalProperties)
		if totalProps > {{.Value}} {
			return fmt.Errorf("too many properties: %d exceeds maximum {{.Value}}", totalProps)
		}
	}
	{{- end}}
	{{- if eq .RuleType "minProperties"}}
	{
		totalProps := {{len $struct.Fields}} + len({{$recv}}.AdditionalProperties)
		if totalProps < {{.Value}} {
			return fmt.Errorf("too few properties: %d is less than minimum {{.Value}}", totalProps)
		}
	}
	{{- end}}
	{{- if .Optional}}
	}
	{{- end}}
	{{- end}}
	{{- if and $struct.AdditionalProperties $struct.AdditionalProperties.Forbidden}}
	if len({{$recv}}.AdditionalProperties) > 0 {
		for k := range {{$recv}}.AdditionalProperties {
			return fmt.Errorf("additional property %q is not allowed", k)
		}
	}
	{{- end}}
	{{- if $struct.HasPatternPropertyValidation}}
	// patternProperties validation: check matched values against sub-schema constraints.
	if len({{$recv}}.PatternProperties) > 0 {
		ppRegexps := []*ecma262.Regexp{
			{{- range $struct.PatternProperties}}
			ecma262.MustCompile({{printf "%q" .Pattern}}, ecmaflags.Unicode),
			{{- end}}
		}
		for k, v := range {{$recv}}.PatternProperties {
			_ = v
			{{- range $i, $pp := $struct.PatternProperties}}
			{{- if or $pp.IsForbidden (gt (len $pp.Validations) 0)}}
			if ppRegexps[{{$i}}].MatchString(k) {
				{{- if $pp.IsForbidden}}
				return fmt.Errorf("patternProperties: key %q matches forbidden pattern %s", k, {{printf "%q" $pp.Pattern}})
				{{- end}}
				{{- range $pp.Validations}}
				{{- if eq .RuleType "ppType"}}
				{
					b := bytes.TrimSpace(v)
					var jt string
					if len(b) == 0 {
						jt = "unknown"
					} else {
						switch b[0] {
						case '"': jt = "string"
						case '{': jt = "object"
						case '[': jt = "array"
						case 't', 'f': jt = "boolean"
						case 'n': jt = "null"
						default:
							jt = "number"
							// Check if it's an integer (no '.' or 'e'/'E')
							isInt := true
							for _, c := range b {
								if c == '.' || c == 'e' || c == 'E' {
									isInt = false
									break
								}
							}
							if isInt {
								jt = "integer"
							}
						}
					}
					{{- $want := ppTypeValue .Value}}
					{{- if eq $want "integer"}}
					if jt != "integer" {
						return fmt.Errorf("patternProperties %s: key %q value must be integer", {{printf "%q" $pp.Pattern}}, k)
					}
					{{- else if eq $want "number"}}
					if jt != "integer" && jt != "number" {
						return fmt.Errorf("patternProperties %s: key %q value must be number", {{printf "%q" $pp.Pattern}}, k)
					}
					{{- else}}
					if jt != {{printf "%q" $want}} {
						return fmt.Errorf("patternProperties %s: key %q value must be {{$want}}", {{printf "%q" $pp.Pattern}}, k)
					}
					{{- end}}
				}
				{{- end}}
				{{- if or (eq .RuleType "ppMinimum") (eq .RuleType "ppMaximum") (eq .RuleType "ppExclusiveMinimum") (eq .RuleType "ppExclusiveMaximum") (eq .RuleType "ppMultipleOf")}}
				{
					var num float64
					if err := json.Unmarshal(v, &num); err == nil {
						{{- if eq .RuleType "ppMinimum"}}
						if num < {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v is less than minimum {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppMaximum"}}
						if num > {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v exceeds maximum {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppExclusiveMinimum"}}
						if num <= {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v must be greater than {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppExclusiveMaximum"}}
						if num >= {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v must be less than {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppMultipleOf"}}
						q := num / {{.Value}}
						if math.Abs(q - math.Round(q)) > 1e-9 {
							return fmt.Errorf("patternProperties %s: key %q value %v is not a multiple of {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
					}
				}
				{{- end}}
				{{- if or (eq .RuleType "ppMinItems") (eq .RuleType "ppMaxItems")}}
				{
					var arr []json.RawMessage
					if err := json.Unmarshal(v, &arr); err == nil {
						{{- if eq .RuleType "ppMinItems"}}
						if len(arr) < {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q array length %d is less than minItems {{.Value}}", {{printf "%q" $pp.Pattern}}, k, len(arr))
						}
						{{- end}}
						{{- if eq .RuleType "ppMaxItems"}}
						if len(arr) > {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q array length %d exceeds maxItems {{.Value}}", {{printf "%q" $pp.Pattern}}, k, len(arr))
						}
						{{- end}}
					}
				}
				{{- end}}
				{{- if or (eq .RuleType "ppMinLength") (eq .RuleType "ppMaxLength")}}
				{
					var s string
					if err := json.Unmarshal(v, &s); err == nil {
						{{- if eq .RuleType "ppMinLength"}}
						if utf8.RuneCountInString(s) < {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q string length is less than minLength {{.Value}}", {{printf "%q" $pp.Pattern}}, k)
						}
						{{- end}}
						{{- if eq .RuleType "ppMaxLength"}}
						if utf8.RuneCountInString(s) > {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q string length exceeds maxLength {{.Value}}", {{printf "%q" $pp.Pattern}}, k)
						}
						{{- end}}
					}
				}
				{{- end}}
				{{- if eq .RuleType "ppPattern"}}
				{
					var s string
					if err := json.Unmarshal(v, &s); err == nil {
						re := regexp.MustCompile({{printf "%q" .Value}})
						if !re.MatchString(s) {
							return fmt.Errorf("patternProperties %s: key %q value does not match pattern {{.Value}}", {{printf "%q" $pp.Pattern}}, k)
						}
					}
				}
				{{- end}}
				{{- end}}
			}
			{{- end}}
			{{- end}}
		}
	}
	{{- end}}
	{{- range $struct.ValidatableFields}}
	{{- if and .IsSlice .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil {
		for _i, _item := range *{{$recv}}.{{.FieldName}} {
			_ = _i
			if err := _item.Validate(); err != nil {
				return err
			}
		}
	}
	{{- else if .IsSlice}}
	for _i, _item := range {{$recv}}.{{.FieldName}} {
		_ = _i
		if err := _item.Validate(); err != nil {
			return err
		}
	}
	{{- else if .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil {
		if err := {{$recv}}.{{.FieldName}}.Validate(); err != nil {
			return err
		}
	}
	{{- else if and .OmitEmpty .ZeroLiteral}}
	if {{$recv}}.{{.FieldName}} != {{.ZeroLiteral}} {
		if err := {{$recv}}.{{.FieldName}}.Validate(); err != nil {
			return err
		}
	}
	{{- else}}
	if err := {{$recv}}.{{.FieldName}}.Validate(); err != nil {
		return err
	}
	{{- end}}
	{{- end}}
	{{- if $struct.HasDependentSchemas}}
	// dependentSchemas: when a trigger key is present, validate against the dependent sub-schema.
	{{- range $dep := $struct.DependentSchemas}}
	if {{$recv}}._jsonKeys[{{printf "%q" $dep.TriggerKey}}] {
		{{- if $dep.IsFalse}}
		return fmt.Errorf("dependentSchema %q: schema is false, object with this property is always invalid", {{printf "%q" $dep.TriggerKey}})
		{{- end}}
		{{- if $dep.AllowedKeys}}
		{
			_allowedKeys := map[string]bool{ {{- range $dep.AllowedKeys}}{{printf "%q" .}}: true, {{end -}} }
			for _k := range {{$recv}}._jsonKeys {
				if !_allowedKeys[_k] {
					return fmt.Errorf("dependentSchema %q: property %q is not allowed", {{printf "%q" $dep.TriggerKey}}, _k)
				}
			}
		}
		{{- end}}
		{{- if $dep.RequiredProps}}
		{{- range $dep.RequiredProps}}
		if !{{$recv}}._jsonKeys[{{printf "%q" .}}] {
			return fmt.Errorf("dependentSchema %q: property %q is required", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" .}})
		}
		{{- end}}
		{{- end}}
		{{- if $dep.MinProperties}}
		if len({{$recv}}._jsonKeys) < {{deref $dep.MinProperties}} {
			return fmt.Errorf("dependentSchema %q: has %d properties, minimum is {{deref $dep.MinProperties}}", {{printf "%q" $dep.TriggerKey}}, len({{$recv}}._jsonKeys))
		}
		{{- end}}
		{{- if $dep.MaxProperties}}
		if len({{$recv}}._jsonKeys) > {{deref $dep.MaxProperties}} {
			return fmt.Errorf("dependentSchema %q: has %d properties, maximum is {{deref $dep.MaxProperties}}", {{printf "%q" $dep.TriggerKey}}, len({{$recv}}._jsonKeys))
		}
		{{- end}}
		{{- if $dep.PropertyTypes}}
		{{- range $pt := $dep.PropertyTypes}}
		if _raw, _ok := {{$recv}}.AdditionalProperties[{{printf "%q" $pt.PropName}}]; _ok {
			var _v any
			if _dErr := json.Unmarshal(_raw, &_v); _dErr == nil {
				{{- if eq $pt.JSONType "integer"}}
				_f, _fOk := _v.(float64)
				if !_fOk || _f != math.Trunc(_f) {
					return fmt.Errorf("dependentSchema %q: property %q: expected integer", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- else if eq $pt.JSONType "number"}}
				if _, _fOk := _v.(float64); !_fOk {
					return fmt.Errorf("dependentSchema %q: property %q: expected number", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- else if eq $pt.JSONType "string"}}
				if _, _sOk := _v.(string); !_sOk {
					return fmt.Errorf("dependentSchema %q: property %q: expected string", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- else if eq $pt.JSONType "boolean"}}
				if _, _bOk := _v.(bool); !_bOk {
					return fmt.Errorf("dependentSchema %q: property %q: expected boolean", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- else if eq $pt.JSONType "null"}}
				if _v != nil {
					return fmt.Errorf("dependentSchema %q: property %q: expected null", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- else if eq $pt.JSONType "array"}}
				if _, _aOk := _v.([]any); !_aOk {
					return fmt.Errorf("dependentSchema %q: property %q: expected array", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- else if eq $pt.JSONType "object"}}
				if _, _oOk := _v.(map[string]any); !_oOk {
					return fmt.Errorf("dependentSchema %q: property %q: expected object", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" $pt.PropName}})
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- end}}
	}
	{{- end}}
	{{- end}}
	{{- if $struct.HasDependentRequired}}
	// dependentRequired: when a trigger key is present, listed properties must also be present.
	{{- range $dep := $struct.DependentRequired}}
	if {{$recv}}._jsonKeys[{{printf "%q" $dep.TriggerKey}}] {
		{{- range $dep.Required}}
		if !{{$recv}}._jsonKeys[{{printf "%q" .}}] {
			return fmt.Errorf("dependentRequired %q: property %q is required", {{printf "%q" $dep.TriggerKey}}, {{printf "%q" .}})
		}
		{{- end}}
	}
	{{- end}}
	{{- end}}
	{{- if $struct.HasPropertyNames}}
	// propertyNames: validate that all property names satisfy the constraint.
	for _pnKey := range {{$recv}}._jsonKeys {
		{{- if $struct.PropertyNames.IsForbidden}}
		return fmt.Errorf("propertyNames: property %q is not allowed (schema is false)", _pnKey)
		{{- end}}
		{{- if $struct.PropertyNames.MaxLength}}
		if utf8.RuneCountInString(_pnKey) > {{deref $struct.PropertyNames.MaxLength}} {
			return fmt.Errorf("propertyNames: property name %q exceeds maxLength {{deref $struct.PropertyNames.MaxLength}}", _pnKey)
		}
		{{- end}}
		{{- if $struct.PropertyNames.MinLength}}
		if utf8.RuneCountInString(_pnKey) < {{deref $struct.PropertyNames.MinLength}} {
			return fmt.Errorf("propertyNames: property name %q is shorter than minLength {{deref $struct.PropertyNames.MinLength}}", _pnKey)
		}
		{{- end}}
		{{- if $struct.PropertyNames.Pattern}}
		if !ecma262.MustCompile({{printf "%q" $struct.PropertyNames.Pattern}}, ecmaflags.Unicode).MatchString(_pnKey) {
			return fmt.Errorf("propertyNames: property name %q does not match pattern %q", _pnKey, {{printf "%q" $struct.PropertyNames.Pattern}})
		}
		{{- end}}
		{{- if $struct.PropertyNames.Enum}}
		{
			_pnAllowed := map[string]bool{
				{{- range $struct.PropertyNames.Enum}}
				{{printf "%q" .}}: true,
				{{- end}}
			}
			if !_pnAllowed[_pnKey] {
				return fmt.Errorf("propertyNames: property name %q is not in the allowed set", _pnKey)
			}
		}
		{{- end}}
	}
	{{- end}}
	{{- if $struct.HasCousinUnevalChecks}}
	// Cousin isolation: allOf/anyOf sub-schemas with their own unevaluatedProperties
	// can only see properties evaluated in their own branch scope.
	{{- range $ci, $cousin := $struct.CousinUnevalChecks}}
	{{- if not $cousin.AllEvaluated}}
	{
		{{- if gt (len $cousin.EvaluatedNames) 0}}
		_cousinEval{{$ci}} := map[string]bool{
			{{- range $cousin.EvaluatedNames}}
			{{printf "%q" .}}: true,
			{{- end}}
		}
		{{- end}}
		{{- if gt (len $cousin.EvalPatterns) 0}}
		_cousinPat{{$ci}} := []*ecma262.Regexp{
			{{- range $cousin.EvalPatterns}}
			ecma262.MustCompile({{printf "%q" .}}, ecmaflags.Unicode),
			{{- end}}
		}
		{{- end}}
		for k := range {{$recv}}._jsonKeys {
			_cEval := false
			{{- if gt (len $cousin.EvaluatedNames) 0}}
			if _cousinEval{{$ci}}[k] { _cEval = true }
			{{- end}}
			{{- if gt (len $cousin.EvalPatterns) 0}}
			if !_cEval {
				for _, _re := range _cousinPat{{$ci}} {
					if _re.MatchString(k) { _cEval = true; break }
				}
			}
			{{- end}}
			if !_cEval {
				{{- if $cousin.IsForbidden}}
				return fmt.Errorf("unevaluated property %q is not allowed", k)
				{{- end}}
			}
		}
	}
	{{- end}}
	{{- end}}
	{{- end}}
	{{- if $struct.HasUnevaluatedProperties}}
	{{- $uneval := $struct.UnevaluatedProperties}}
	{{- if and (not $uneval.IsAllowed) (not $uneval.AllEvaluated)}}
	// unevaluatedProperties: check overflow map for properties not covered by evaluated set.
	{
		{{- if or (gt (len $uneval.EvaluatedNames) 0) $uneval.HasConditionalEvals}}
		evaluatedNames := map[string]bool{
			{{- range $uneval.EvaluatedNames}}
			{{printf "%q" .}}: true,
			{{- end}}
		}
		{{- end}}
		{{- if gt (len $uneval.EvaluatedPatterns) 0}}
		evaluatedPatterns := []*ecma262.Regexp{
			{{- range $uneval.EvaluatedPatterns}}
			ecma262.MustCompile({{printf "%q" .}}, ecmaflags.Unicode),
			{{- end}}
		}
		{{- end}}
		{{- /* Runtime conditional branches: add properties to evaluated set dynamically. */}}
		{{- range $uneval.ConditionalEvals}}
		{{- if eq .Kind "dependentSchema"}}
		// dependentSchemas: {{.TriggerKey}} — only evaluated when trigger key is present.
		if {{$recv}}._jsonKeys[{{printf "%q" .TriggerKey}}] {
			{{- range .Branch.Names}}
			evaluatedNames[{{printf "%q" .}}] = true
			{{- end}}
		}
		{{- else if eq .Kind "ifThenElse"}}
		// if/then/else: evaluate if-condition at runtime, add then or else properties.
		{
			_ifMatch := true
			{{- range .IfBranch.RequiredKeys}}
			if !{{$recv}}._jsonKeys[{{printf "%q" .}}] {
				_ifMatch = false
			}
			{{- end}}
			{{- range .IfBranch.ConstChecks}}
			if _ifMatch {
				if _rv, _ok := {{$recv}}._jsonRawProps[{{printf "%q" .PropertyName}}]; !_ok || string(_rv) != {{printf "%q" .JSONValue}} {
					_ifMatch = false
				}
			}
			{{- end}}
			if _ifMatch {
				{{- if .ThenBranch}}
				{{- range .ThenBranch.Names}}
				evaluatedNames[{{printf "%q" .}}] = true
				{{- end}}
				{{- end}}
			} else {
				{{- if .ElseBranch}}
				{{- range .ElseBranch.Names}}
				evaluatedNames[{{printf "%q" .}}] = true
				{{- end}}
				{{- end}}
			}
		}
		{{- else if eq .Kind "anyOf"}}
		// anyOf: add evaluated properties from matching branches.
		{{- range $bi, $branch := .Branches}}
		{
			_branchMatch := true
			{{- range $branch.RequiredKeys}}
			if !{{$recv}}._jsonKeys[{{printf "%q" .}}] {
				_branchMatch = false
			}
			{{- end}}
			{{- range $branch.ConstChecks}}
			if _branchMatch {
				if _rv, _ok := {{$recv}}._jsonRawProps[{{printf "%q" .PropertyName}}]; !_ok || string(_rv) != {{printf "%q" .JSONValue}} {
					_branchMatch = false
				}
			}
			{{- end}}
			if _branchMatch {
				{{- range $branch.Names}}
				evaluatedNames[{{printf "%q" .}}] = true
				{{- end}}
			}
		}
		{{- end}}
		{{- else if eq .Kind "oneOf"}}
		// oneOf: add evaluated properties from the single matching branch.
		{
			_oneOfMatchCount := 0
			_oneOfMatchIdx := -1
			{{- range $bi, $branch := .Branches}}
			{
				_branchMatch := true
				{{- range $branch.RequiredKeys}}
				if !{{$recv}}._jsonKeys[{{printf "%q" .}}] {
					_branchMatch = false
				}
				{{- end}}
				{{- range $branch.ConstChecks}}
				if _branchMatch {
					if _rv, _ok := {{$recv}}._jsonRawProps[{{printf "%q" .PropertyName}}]; !_ok || string(_rv) != {{printf "%q" .JSONValue}} {
						_branchMatch = false
					}
				}
				{{- end}}
				if _branchMatch {
					_oneOfMatchCount++
					_oneOfMatchIdx = {{$bi}}
				}
			}
			{{- end}}
			if _oneOfMatchCount != 1 {
				return fmt.Errorf("oneOf: expected exactly 1 matching branch, got %d", _oneOfMatchCount)
			}
			_ = _oneOfMatchIdx
			{{- range $bi, $branch := .Branches}}
			{{- if or $branch.Names $branch.Patterns $branch.AllEvaluated}}
			if _oneOfMatchIdx == {{$bi}} {
				{{- range $branch.Names}}
				evaluatedNames[{{printf "%q" .}}] = true
				{{- end}}
				{{- if $branch.AllEvaluated}}
				// Matching branch evaluates all properties.
				for _k := range {{$recv}}._jsonKeys {
					evaluatedNames[_k] = true
				}
				{{- end}}
				{{- range $branch.Patterns}}
				{
					_re := ecma262.MustCompile({{printf "%q" .}}, ecmaflags.Unicode)
					for _k := range {{$recv}}._jsonKeys {
						if _re.MatchString(_k) {
							evaluatedNames[_k] = true
						}
					}
				}
				{{- end}}
			}
			{{- end}}
			{{- end}}
		}
		{{- end}}
		{{- end}}
		for k, v := range {{$recv}}.AdditionalProperties {
			evaluated := false
			_ = v
			{{- if or (gt (len $uneval.EvaluatedNames) 0) $uneval.HasConditionalEvals}}
			if evaluatedNames[k] {
				evaluated = true
			}
			{{- end}}
			{{- if gt (len $uneval.EvaluatedPatterns) 0}}
			if !evaluated {
				for _, re := range evaluatedPatterns {
					if re.MatchString(k) {
						evaluated = true
						break
					}
				}
			}
			{{- end}}
			if !evaluated {
				{{- if $uneval.IsForbidden}}
				return fmt.Errorf("unevaluated property %q is not allowed", k)
				{{- else if $uneval.HasSchemaValuedUnevalProps}}
				{{- if $uneval.ValueType}}
				var _uVal {{$uneval.ValueType}}
				if _uErr := json.Unmarshal(v, &_uVal); _uErr != nil {
					return fmt.Errorf("unevaluated property %q: %w", k, _uErr)
				}
				{{- range $uneval.Validations}}
				{{- template "validation_rule_inline" .}}
				{{- end}}
				{{- end}}
				{{- end}}
			}
		}
		{{- if $struct.HasPatternProperties}}
		for k, v := range {{$recv}}.PatternProperties {
			evaluated := false
			_ = v
			{{- if or (gt (len $uneval.EvaluatedNames) 0) $uneval.HasConditionalEvals}}
			if evaluatedNames[k] {
				evaluated = true
			}
			{{- end}}
			{{- if gt (len $uneval.EvaluatedPatterns) 0}}
			if !evaluated {
				for _, re := range evaluatedPatterns {
					if re.MatchString(k) {
						evaluated = true
						break
					}
				}
			}
			{{- end}}
			if !evaluated {
				{{- if $uneval.IsForbidden}}
				return fmt.Errorf("unevaluated property %q is not allowed", k)
				{{- else if $uneval.HasSchemaValuedUnevalProps}}
				{{- if $uneval.ValueType}}
				var _uVal {{$uneval.ValueType}}
				if _uErr := json.Unmarshal(v, &_uVal); _uErr != nil {
					return fmt.Errorf("unevaluated property %q: %w", k, _uErr)
				}
				{{- range $uneval.Validations}}
				{{- template "validation_rule_inline" .}}
				{{- end}}
				{{- end}}
				{{- end}}
			}
		}
		{{- end}}
	}
	{{- end}}
	{{- end}}
	return nil
}
{{- end}}

{{- /* validation_rule_inline emits a validation check on _uVal for a single rule.
       Used by schema-valued unevaluatedProperties to validate each overflow value.
       The variable k (property name) is available for error messages. */}}
{{define "validation_rule_inline"}}
{{- if eq .RuleType "minLength"}}
				if utf8.RuneCountInString(_uVal) < {{.Value}} {
					return fmt.Errorf("unevaluated property %q: length %d is less than minimum {{.Value}}", k, utf8.RuneCountInString(_uVal))
				}
{{- end}}
{{- if eq .RuleType "maxLength"}}
				if utf8.RuneCountInString(_uVal) > {{.Value}} {
					return fmt.Errorf("unevaluated property %q: length %d exceeds maximum {{.Value}}", k, utf8.RuneCountInString(_uVal))
				}
{{- end}}
{{- if eq .RuleType "minimum"}}
				if float64(_uVal) < {{.Value}} {
					return fmt.Errorf("unevaluated property %q: value %v is less than minimum {{.Value}}", k, _uVal)
				}
{{- end}}
{{- if eq .RuleType "maximum"}}
				if float64(_uVal) > {{.Value}} {
					return fmt.Errorf("unevaluated property %q: value %v exceeds maximum {{.Value}}", k, _uVal)
				}
{{- end}}
{{- if eq .RuleType "exclusiveMinimum"}}
				if float64(_uVal) <= {{.Value}} {
					return fmt.Errorf("unevaluated property %q: value %v must be greater than {{.Value}}", k, _uVal)
				}
{{- end}}
{{- if eq .RuleType "exclusiveMaximum"}}
				if float64(_uVal) >= {{.Value}} {
					return fmt.Errorf("unevaluated property %q: value %v must be less than {{.Value}}", k, _uVal)
				}
{{- end}}
{{- if eq .RuleType "pattern"}}
				{
					_re := regexp.MustCompile({{printf "%q" .Value}})
					if !_re.MatchString(_uVal) {
						return fmt.Errorf("unevaluated property %q: value does not match pattern %s", k, {{printf "%q" .Value}})
					}
				}
{{- end}}
{{- if eq .RuleType "multipleOf"}}
				{
					_q := float64(_uVal) / {{.Value}}
					if math.Abs(_q - math.Round(_q)) > 1e-9 {
						return fmt.Errorf("unevaluated property %q: value %v is not a multiple of {{.Value}}", k, _uVal)
					}
				}
{{- end}}
{{- end}}
