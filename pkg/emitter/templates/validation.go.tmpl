{{define "validate"}}
{{- $struct := . -}}
{{- $recv := receiverName .Name -}}

// Validate checks {{$struct.Name}} against its JSON Schema constraints.
func ({{$recv}} {{$struct.Name}}) Validate() error {
	{{- if $struct.AcceptNonObject}}
	// Non-object data was silently accepted — validate non-object constraints if any.
	if {{$recv}}._nonObject {
		{{- if gt (len $struct.NonObjectValidations) 0}}
		v := {{$recv}}._rawNonObject
		_ = v
		{{- range $struct.NonObjectValidations}}
		{{- if or (eq .RuleType "ppMinimum") (eq .RuleType "ppMaximum") (eq .RuleType "ppExclusiveMinimum") (eq .RuleType "ppExclusiveMaximum") (eq .RuleType "ppMultipleOf")}}
		{
			var num float64
			if err := json.Unmarshal(v, &num); err == nil {
				{{- if eq .RuleType "ppMinimum"}}
				if num < {{.Value}} {
					return fmt.Errorf("value %v is less than minimum {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppMaximum"}}
				if num > {{.Value}} {
					return fmt.Errorf("value %v exceeds maximum {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppExclusiveMinimum"}}
				if num <= {{.Value}} {
					return fmt.Errorf("value %v must be greater than {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppExclusiveMaximum"}}
				if num >= {{.Value}} {
					return fmt.Errorf("value %v must be less than {{.Value}}", num)
				}
				{{- end}}
				{{- if eq .RuleType "ppMultipleOf"}}
				q := num / {{.Value}}
				if math.Abs(q - math.Round(q)) > 1e-9 {
					return fmt.Errorf("value %v is not a multiple of {{.Value}}", num)
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- if or (eq .RuleType "ppMinLength") (eq .RuleType "ppMaxLength")}}
		{
			var s string
			if err := json.Unmarshal(v, &s); err == nil {
				{{- if eq .RuleType "ppMinLength"}}
				if utf8.RuneCountInString(s) < {{.Value}} {
					return fmt.Errorf("string length is less than minLength {{.Value}}")
				}
				{{- end}}
				{{- if eq .RuleType "ppMaxLength"}}
				if utf8.RuneCountInString(s) > {{.Value}} {
					return fmt.Errorf("string length exceeds maxLength {{.Value}}")
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- if eq .RuleType "ppPattern"}}
		{
			var s string
			if err := json.Unmarshal(v, &s); err == nil {
				re := regexp.MustCompile({{printf "%q" .Value}})
				if !re.MatchString(s) {
					return fmt.Errorf("value does not match pattern {{.Value}}")
				}
			}
		}
		{{- end}}
		{{- if or (eq .RuleType "ppMinItems") (eq .RuleType "ppMaxItems")}}
		{
			var arr []json.RawMessage
			if err := json.Unmarshal(v, &arr); err == nil {
				{{- if eq .RuleType "ppMinItems"}}
				if len(arr) < {{.Value}} {
					return fmt.Errorf("array length %d is less than minItems {{.Value}}", len(arr))
				}
				{{- end}}
				{{- if eq .RuleType "ppMaxItems"}}
				if len(arr) > {{.Value}} {
					return fmt.Errorf("array length %d exceeds maxItems {{.Value}}", len(arr))
				}
				{{- end}}
			}
		}
		{{- end}}
		{{- if eq .RuleType "ppType"}}
		{
			b := bytes.TrimSpace(v)
			var jt string
			if len(b) == 0 {
				jt = "unknown"
			} else {
				switch b[0] {
				case '"': jt = "string"
				case '{': jt = "object"
				case '[': jt = "array"
				case 't', 'f': jt = "boolean"
				case 'n': jt = "null"
				default:
					jt = "number"
					isInt := true
					for _, c := range b {
						if c == '.' || c == 'e' || c == 'E' {
							isInt = false
							break
						}
					}
					if isInt {
						jt = "integer"
					}
				}
			}
			{{- $want := ppTypeValue .Value}}
			{{- if eq $want "integer"}}
			if jt != "integer" {
				return fmt.Errorf("value must be integer")
			}
			{{- else if eq $want "number"}}
			if jt != "integer" && jt != "number" {
				return fmt.Errorf("value must be number")
			}
			{{- else}}
			if jt != {{printf "%q" $want}} {
				return fmt.Errorf("value must be {{$want}}")
			}
			{{- end}}
		}
		{{- end}}
		{{- end}}
		{{- end}}
		return nil
	}
	{{- end}}
	{{- range $struct.Validations}}
	{{- if .Optional}}
	if {{$recv}}._jsonKeys[{{printf "%q" .JSONName}}] {
	{{- end}}
	{{- if eq .RuleType "minLength"}}
	if utf8.RuneCountInString({{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: length %d is less than minimum {{.Value}}", utf8.RuneCountInString({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- if eq .RuleType "maxLength"}}
	if utf8.RuneCountInString({{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: length %d exceeds maximum {{.Value}}", utf8.RuneCountInString({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- if eq .RuleType "minimum"}}
	if float64({{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v is less than minimum {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "maximum"}}
	if float64({{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v exceeds maximum {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMinimum"}}
	if float64({{$recv}}.{{.FieldName}}) <= {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v must be greater than {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "exclusiveMaximum"}}
	if float64({{$recv}}.{{.FieldName}}) >= {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: value %v must be less than {{.Value}}", {{$recv}}.{{.FieldName}})
	}
	{{- end}}
	{{- if eq .RuleType "multipleOf"}}
	{
		q := float64({{$recv}}.{{.FieldName}}) / {{.Value}}
		if math.Abs(q - math.Round(q)) > 1e-9 {
			return fmt.Errorf("{{.JSONName}}: value %v is not a multiple of {{.Value}}", {{$recv}}.{{.FieldName}})
		}
	}
	{{- end}}
	{{- if eq .RuleType "pattern"}}
	if matched, _ := ecma262.MatchString({{printf "%q" .Value}}, ecmaflags.Unicode, {{$recv}}.{{.FieldName}}); !matched {
		return fmt.Errorf("{{.JSONName}}: value %q does not match pattern %s", {{$recv}}.{{.FieldName}}, {{printf "%q" .Value}})
	}
	{{- end}}
	{{- if eq .RuleType "minItems"}}
	{{- if .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil && len(*{{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, minimum is {{.Value}}", len(*{{$recv}}.{{.FieldName}}))
	}
	{{- else}}
	if len({{$recv}}.{{.FieldName}}) < {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, minimum is {{.Value}}", len({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- end}}
	{{- if eq .RuleType "maxItems"}}
	{{- if .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil && len(*{{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, maximum is {{.Value}}", len(*{{$recv}}.{{.FieldName}}))
	}
	{{- else}}
	if len({{$recv}}.{{.FieldName}}) > {{.Value}} {
		return fmt.Errorf("{{.JSONName}}: has %d items, maximum is {{.Value}}", len({{$recv}}.{{.FieldName}}))
	}
	{{- end}}
	{{- end}}
	{{- if eq .RuleType "uniqueItems"}}
	{
		{{- if .IsPointer}}
		arr := *{{$recv}}.{{.FieldName}}
		{{- else}}
		arr := {{$recv}}.{{.FieldName}}
		{{- end}}
		seen := make(map[string]bool, len(arr))
		for i, item := range arr {
			b, err := json.Marshal(item)
			if err != nil {
				return fmt.Errorf("{{.JSONName}}: uniqueItems check: marshal error at index %d: %w", i, err)
			}
			key := string(b)
			if seen[key] {
				return fmt.Errorf("{{.JSONName}}: items are not unique (duplicate at index %d)", i)
			}
			seen[key] = true
		}
	}
	{{- end}}
	{{- if eq .RuleType "forbidden"}}
	if {{$recv}}.{{.FieldName}} != nil {
		return fmt.Errorf("{{.JSONName}}: property is forbidden (not: {})")
	}
	{{- end}}
	{{- if eq .RuleType "maxProperties"}}
	{
		totalProps := {{len $struct.Fields}} + len({{$recv}}.AdditionalProperties)
		if totalProps > {{.Value}} {
			return fmt.Errorf("too many properties: %d exceeds maximum {{.Value}}", totalProps)
		}
	}
	{{- end}}
	{{- if eq .RuleType "minProperties"}}
	{
		totalProps := {{len $struct.Fields}} + len({{$recv}}.AdditionalProperties)
		if totalProps < {{.Value}} {
			return fmt.Errorf("too few properties: %d is less than minimum {{.Value}}", totalProps)
		}
	}
	{{- end}}
	{{- if .Optional}}
	}
	{{- end}}
	{{- end}}
	{{- if and $struct.AdditionalProperties $struct.AdditionalProperties.Forbidden}}
	if len({{$recv}}.AdditionalProperties) > 0 {
		for k := range {{$recv}}.AdditionalProperties {
			return fmt.Errorf("additional property %q is not allowed", k)
		}
	}
	{{- end}}
	{{- if $struct.HasPatternPropertyValidation}}
	// patternProperties validation: check matched values against sub-schema constraints.
	if len({{$recv}}.PatternProperties) > 0 {
		ppRegexps := []*ecma262.Regexp{
			{{- range $struct.PatternProperties}}
			ecma262.MustCompile({{printf "%q" .Pattern}}, ecmaflags.Unicode),
			{{- end}}
		}
		for k, v := range {{$recv}}.PatternProperties {
			_ = v
			{{- range $i, $pp := $struct.PatternProperties}}
			{{- if or $pp.IsForbidden (gt (len $pp.Validations) 0)}}
			if ppRegexps[{{$i}}].MatchString(k) {
				{{- if $pp.IsForbidden}}
				return fmt.Errorf("patternProperties: key %q matches forbidden pattern %s", k, {{printf "%q" $pp.Pattern}})
				{{- end}}
				{{- range $pp.Validations}}
				{{- if eq .RuleType "ppType"}}
				{
					b := bytes.TrimSpace(v)
					var jt string
					if len(b) == 0 {
						jt = "unknown"
					} else {
						switch b[0] {
						case '"': jt = "string"
						case '{': jt = "object"
						case '[': jt = "array"
						case 't', 'f': jt = "boolean"
						case 'n': jt = "null"
						default:
							jt = "number"
							// Check if it's an integer (no '.' or 'e'/'E')
							isInt := true
							for _, c := range b {
								if c == '.' || c == 'e' || c == 'E' {
									isInt = false
									break
								}
							}
							if isInt {
								jt = "integer"
							}
						}
					}
					{{- $want := ppTypeValue .Value}}
					{{- if eq $want "integer"}}
					if jt != "integer" {
						return fmt.Errorf("patternProperties %s: key %q value must be integer", {{printf "%q" $pp.Pattern}}, k)
					}
					{{- else if eq $want "number"}}
					if jt != "integer" && jt != "number" {
						return fmt.Errorf("patternProperties %s: key %q value must be number", {{printf "%q" $pp.Pattern}}, k)
					}
					{{- else}}
					if jt != {{printf "%q" $want}} {
						return fmt.Errorf("patternProperties %s: key %q value must be {{$want}}", {{printf "%q" $pp.Pattern}}, k)
					}
					{{- end}}
				}
				{{- end}}
				{{- if or (eq .RuleType "ppMinimum") (eq .RuleType "ppMaximum") (eq .RuleType "ppExclusiveMinimum") (eq .RuleType "ppExclusiveMaximum") (eq .RuleType "ppMultipleOf")}}
				{
					var num float64
					if err := json.Unmarshal(v, &num); err == nil {
						{{- if eq .RuleType "ppMinimum"}}
						if num < {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v is less than minimum {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppMaximum"}}
						if num > {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v exceeds maximum {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppExclusiveMinimum"}}
						if num <= {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v must be greater than {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppExclusiveMaximum"}}
						if num >= {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q value %v must be less than {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
						{{- if eq .RuleType "ppMultipleOf"}}
						q := num / {{.Value}}
						if math.Abs(q - math.Round(q)) > 1e-9 {
							return fmt.Errorf("patternProperties %s: key %q value %v is not a multiple of {{.Value}}", {{printf "%q" $pp.Pattern}}, k, num)
						}
						{{- end}}
					}
				}
				{{- end}}
				{{- if or (eq .RuleType "ppMinItems") (eq .RuleType "ppMaxItems")}}
				{
					var arr []json.RawMessage
					if err := json.Unmarshal(v, &arr); err == nil {
						{{- if eq .RuleType "ppMinItems"}}
						if len(arr) < {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q array length %d is less than minItems {{.Value}}", {{printf "%q" $pp.Pattern}}, k, len(arr))
						}
						{{- end}}
						{{- if eq .RuleType "ppMaxItems"}}
						if len(arr) > {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q array length %d exceeds maxItems {{.Value}}", {{printf "%q" $pp.Pattern}}, k, len(arr))
						}
						{{- end}}
					}
				}
				{{- end}}
				{{- if or (eq .RuleType "ppMinLength") (eq .RuleType "ppMaxLength")}}
				{
					var s string
					if err := json.Unmarshal(v, &s); err == nil {
						{{- if eq .RuleType "ppMinLength"}}
						if utf8.RuneCountInString(s) < {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q string length is less than minLength {{.Value}}", {{printf "%q" $pp.Pattern}}, k)
						}
						{{- end}}
						{{- if eq .RuleType "ppMaxLength"}}
						if utf8.RuneCountInString(s) > {{.Value}} {
							return fmt.Errorf("patternProperties %s: key %q string length exceeds maxLength {{.Value}}", {{printf "%q" $pp.Pattern}}, k)
						}
						{{- end}}
					}
				}
				{{- end}}
				{{- if eq .RuleType "ppPattern"}}
				{
					var s string
					if err := json.Unmarshal(v, &s); err == nil {
						re := regexp.MustCompile({{printf "%q" .Value}})
						if !re.MatchString(s) {
							return fmt.Errorf("patternProperties %s: key %q value does not match pattern {{.Value}}", {{printf "%q" $pp.Pattern}}, k)
						}
					}
				}
				{{- end}}
				{{- end}}
			}
			{{- end}}
			{{- end}}
		}
	}
	{{- end}}
	{{- range $struct.ValidatableFields}}
	{{- if .IsPointer}}
	if {{$recv}}.{{.FieldName}} != nil {
		if err := {{$recv}}.{{.FieldName}}.Validate(); err != nil {
			return err
		}
	}
	{{- else if and .OmitEmpty .ZeroLiteral}}
	if {{$recv}}.{{.FieldName}} != {{.ZeroLiteral}} {
		if err := {{$recv}}.{{.FieldName}}.Validate(); err != nil {
			return err
		}
	}
	{{- else}}
	if err := {{$recv}}.{{.FieldName}}.Validate(); err != nil {
		return err
	}
	{{- end}}
	{{- end}}
	{{- if $struct.HasDependentSchemas}}
	// dependentSchemas: when a trigger key is present, only the allowed keys are valid.
	{{- range $struct.DependentSchemas}}
	if {{$recv}}._jsonKeys[{{printf "%q" .TriggerKey}}] {
		allowedKeys := map[string]bool{ {{- range .AllowedKeys}}{{printf "%q" .}}: true, {{end -}} }
		for k := range {{$recv}}._jsonKeys {
			if !allowedKeys[k] {
				return fmt.Errorf("dependentSchema %q: property %q is not allowed", {{printf "%q" .TriggerKey}}, k)
			}
		}
	}
	{{- end}}
	{{- end}}
	return nil
}
{{- end}}
