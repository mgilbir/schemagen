{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Coordinate",
  "description": "A tuple of fixed positional items",
  "type": "array",
  "prefixItems": [
    {
      "type": "number",
      "description": "Latitude"
    },
    {
