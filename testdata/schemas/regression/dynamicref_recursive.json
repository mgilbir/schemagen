{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://test.json-schema.org/relative-dynamic-reference-without-bookend/root",
  "$dynamicAnchor": "meta",
  "type": "object",
  "properties": {
    "foo": {
      "const": "pass"
    }
  },
  "$ref": "extended",
  "$defs": {
    "extended": {
      "$id": "extended",
      "$anchor": "meta",
      "type": "object",
      "properties": {
        "bar": {
          "$ref": "bar"
        }
      }
    },
    "bar": {
      "$id": "bar",
      "type": "object",
      "properties": {
        "baz": {
          "$dynamicRef": "extended#meta"
        }
      }
    }
  }
}