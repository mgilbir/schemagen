{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Crossed",
  "type": "object",
  "allOf": [
    {
      "oneOf": [
        {
          "properties": {
            "kind": { "const": "left" },
            "a": { "type": "string" },
            "b": { "type": "number" }
          },
          "required": ["kind", "a", "b"]
        },
        {
          "properties": {
            "kind": { "const": "right" },
            "a": { "type": "number" },
            "b": { "type": "string" }
          },
          "required": ["kind", "a", "b"]
        }
      ]
    }
  ]
}
