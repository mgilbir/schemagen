{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Playlist",
  "type": "object",
  "definitions": {
    "trackList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 1 }
        },
        "required": ["title"]
      }
    }
  },
  "properties": {
    "name": { "type": "string" },
    "tracks": { "$ref": "#/definitions/trackList" }
  },
  "required": ["name"]
}
