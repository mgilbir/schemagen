{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Employee",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name"]
    },
    {
      "type": "object",
      "properties": {
        "employee_id": { "type": "string" },
        "department": { "type": "string" }
      },
      "required": ["employee_id"]
    }
  ]
}
