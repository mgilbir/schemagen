{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SearchResult",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "result": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string" }
          }
        },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      ]
    }
  },
  "required": ["id"]
}
