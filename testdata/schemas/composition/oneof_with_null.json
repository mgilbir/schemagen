{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "type": "object",
  "$defs": {
    "DatabaseConfig": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer" }
      },
      "required": ["host"]
    }
  },
  "properties": {
    "name": { "type": "string" },
    "database": {
      "oneOf": [
        { "$ref": "#/$defs/DatabaseConfig" },
        { "type": "null" }
      ]
    }
  },
  "required": ["name"]
}
