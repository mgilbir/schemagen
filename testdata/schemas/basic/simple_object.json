{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Person",
  "description": "A person record",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Full name"
    },
    "age": {
      "type": "integer",
      "description": "Age in years"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "active": {
      "type": "boolean"
    }
  },
  "required": ["name", "email"]
}
