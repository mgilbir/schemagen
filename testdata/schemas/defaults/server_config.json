{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServerConfig",
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "default": "localhost"
    },
    "port": {
      "type": "integer",
      "default": 8080
    },
    "timeout": {
      "type": "number",
      "default": 30.5
    },
    "debug": {
      "type": "boolean",
      "default": true
    },
    "log_level": {
      "type": "string",
      "default": "info"
    },
    "max_retries": {
      "type": "integer",
      "default": 3
    },
    "name": {
      "type": "string"
    }
  },
  "required": ["name"]
}
